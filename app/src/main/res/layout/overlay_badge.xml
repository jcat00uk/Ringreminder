<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- STATE 1: Collapsed pill -->
    <LinearLayout
        android:id="@+id/collapsed_badge"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="4dp"
        android:elevation="8dp">

        <TextView
            android:id="@+id/pill_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium" />

        <View
            android:id="@+id/multi_dot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/dot_indicator"
            android:visibility="gone" />

        <!-- Subtle separator before X -->
        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_marginStart="10dp"
            android:background="#50FFFFFF" />

        <ImageButton
            android:id="@+id/btn_close_pill"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="2dp"
            android:src="@drawable/ic_close"
            android:background="@android:color/transparent"
            android:padding="9dp"
            android:contentDescription="Dismiss" />
    </LinearLayout>

    <!-- STATE 2: Expanded card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/expanded_card"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFFFF"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Coloured header (background set in code) -->
            <LinearLayout
                android:id="@+id/card_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="6dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/expanded_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white" />

                <ImageButton
                    android:id="@+id/btn_close_card"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_close"
                    android:background="@android:color/transparent"
                    android:padding="9dp"
                    android:contentDescription="Close" />
            </LinearLayout>

            <!-- Body -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/expanded_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:lineSpacingMultiplier="1.4" />

                <Button
                    android:id="@+id/btn_fix"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:text="Fix it"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- STATE 3: Inline confirmation -->
    <androidx.cardview.widget.CardView
        android:id="@+id/confirmation_card"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFFFF"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hide until ringer state changes?"
                android:textSize="15sp"
                android:textColor="#1A1A1A"
                android:lineSpacingMultiplier="1.3" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/btn_cancel_dismiss"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Cancel"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btn_confirm_dismiss"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:text="Hide"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>
