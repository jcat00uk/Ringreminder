<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- STATE 1: Collapsed pill -->
    <LinearLayout
        android:id="@+id/collapsed_badge"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:elevation="8dp">

        <TextView
            android:id="@+id/pill_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium" />

        <View
            android:id="@+id/multi_dot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/dot_indicator"
            android:visibility="gone" />

    </LinearLayout>

    <!-- STATE 2: Expanded card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/expanded_card"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFFFF"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Coloured header -->
            <LinearLayout
                android:id="@+id/card_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="6dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/expanded_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white" />

                <ImageButton
                    android:id="@+id/btn_settings_card"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_settings"
                    android:background="@android:color/transparent"
                    android:padding="9dp"
                    android:contentDescription="Settings" />

                <ImageButton
                    android:id="@+id/btn_close_card"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_close"
                    android:background="@android:color/transparent"
                    android:padding="9dp"
                    android:contentDescription="Close" />
            </LinearLayout>

            <!-- Body -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/expanded_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:lineSpacingMultiplier="1.4" />

                <!-- Secondary condition chips (Feature 5) -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_secondary_conditions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"
                    app:chipSpacingHorizontal="4dp" />

                <!-- Primary fix button — wrap_content height so long labels like "Dismiss Do Not Disturb" don't clip -->
                <Button
                    android:id="@+id/btn_fix"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:layout_marginTop="14dp"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    android:maxLines="2" />

                <!-- Snooze alerts row -->
                <LinearLayout
                    android:id="@+id/row_snooze"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/snooze_alerts_for"
                        android:textSize="14sp"
                        android:textColor="#555555" />

                    <TextView
                        android:id="@+id/txt_snooze_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/snooze_30min"
                        android:textSize="14sp"
                        android:textColor="?attr/colorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" ▼"
                        android:textSize="12sp"
                        android:textColor="?attr/colorPrimary" />
                </LinearLayout>

                <!-- Scheduled auto-fix countdown (shown when one-shot auto-fix is pending) -->
                <LinearLayout
                    android:id="@+id/row_auto_fix_scheduled"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/txt_auto_fix_scheduled"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="#777777"
                        android:fontFamily="sans-serif-italic" />

                    <Button
                        android:id="@+id/btn_cancel_auto_fix"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/overlay_cancel"
                        android:textSize="12sp"
                        android:minHeight="0dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />
                </LinearLayout>

                <!-- Daily auto-unmute info row (shown when daily schedule is set) -->
                <LinearLayout
                    android:id="@+id/row_daily_unmute"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/txt_daily_unmute"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="#777777"
                        android:fontFamily="sans-serif-italic" />

                    <Button
                        android:id="@+id/btn_daily_unmute_change"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/overlay_change"
                        android:textSize="12sp"
                        android:minHeight="0dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />
                </LinearLayout>

                <!-- Auto-fix in row (Pro only, shown/hidden in code) -->
                <LinearLayout
                    android:id="@+id/row_auto_fix"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/auto_fix_in"
                        android:textSize="14sp"
                        android:textColor="#555555" />

                    <TextView
                        android:id="@+id/txt_auto_fix_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/snooze_1hour"
                        android:textSize="14sp"
                        android:textColor="?attr/colorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" ▼"
                        android:textSize="12sp"
                        android:textColor="?attr/colorPrimary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- STATE 3: Docked nub (snapped to screen edge) -->
    <ImageView
        android:id="@+id/docked_nub"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_notification"
        android:tint="@android:color/white"
        android:padding="10dp"
        android:scaleType="fitCenter"
        android:elevation="8dp"
        android:contentDescription="Ring Reminder"
        android:visibility="gone" />

</FrameLayout>
