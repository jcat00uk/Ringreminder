    <string name="onboard_overlay_desc">This allows Ring Reminder to show a small floating badge on your screen so you can see and fix ringer issues without switching apps.</string>
    <string name="onboard_dnd_title">Do Not Disturb access</string>
    <string name="onboard_dnd_desc">This lets Ring Reminder detect when Do Not Disturb is active and automatically turn it off so you can receive calls.</string>
