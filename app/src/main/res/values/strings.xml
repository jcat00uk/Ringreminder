    <string name="onboard_notif_title">Notification permission</string>
    <string name="onboard_notif_desc">Ring Reminder needs to show notifications to keep you informed about your ringer state and let you fix issues without opening the app.</string>
    <string name="onboard_overlay_title">Draw over other apps</string>
    <string name="onboard_overlay_desc">This allows Ring Reminder to show a small floating badge on your screen so you can see and fix ringer issues without switching apps.</string>
    <string name="onboard_dnd_title">Do Not Disturb access</string>
    <string name="onboard_dnd_desc">This lets Ring Reminder detect when Do Not Disturb is active and automatically turn it off so you can receive calls.</string>
    <string name="onboard_battery_title">Battery optimisation</string>
    <string name="onboard_battery_desc">Exempting Ring Reminder from battery optimisation ensures it keeps running reliably in the background, even when your phone has been idle.</string>

